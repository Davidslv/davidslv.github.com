[17.789, "o", "\u001b[91mfirm gate: push blocked by 5 un-waived finding(s):\u001b[0m\r\n"]
[17.849, "o", "  - [\u001b[33mhatch-lock\u001b[0m] config/initializers/inflections.rb: custom inflection overrides\r\n"]
[17.909, "o", "      Rails' inflector \u2014 record a reason in the ledger\r\n"]
[17.969, "o", "  - [\u001b[33mhatch-lock\u001b[0m] app/models/legacy_order.rb: `self.table_name =` override bends\r\n"]
[18.029, "o", "      the schema-inferred mapping\r\n"]
[18.089, "o", "  - [\u001b[33mrest-shape\u001b[0m] config/routes.rb:16: `post` verb route steps off the seven\r\n"]
[18.149, "o", "      RESTful actions \u2014 prefer `resources`\r\n"]
[18.209, "o", "  - [\u001b[33mtdd-private-probe\u001b[0m] test/models/work_item_probe_test.rb: spec probes a\r\n"]
[18.269, "o", "      private method via `.send(:\u2026)`\r\n"]
[18.329, "o", "\u001b[90m  (+1 more)\u001b[0m\r\n"]
[18.389, "o", "\r\n"]
[18.449, "o", "Fix them, or waive one with a reason and re-push:\r\n"]
[18.509, "o", "  \u001b[36mFIRM_OVERRIDE=\"<rule>@<file>: <reason>\" git push\u001b[0m\r\n"]
